# ----------------------------------------------------------------------------
# VibeQuarter — environment. Copy to .env.local. The app runs WITHOUT these
# (auth + data are mocked) so you can preview immediately; add them to switch on
# real auth, the database, the booking brain, and the WhatsApp/voice channels.
# ----------------------------------------------------------------------------

# --- Clerk (auth, organizations / multi-tenancy) ----------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
# Production user sync: the `whsec_...` signing secret of the Clerk webhook
# endpoint (Dashboard → Webhooks). Point the endpoint at
#   https://<domain>/api/clerk/webhook   subscribed to user.created/updated/deleted.
# In dev the polling daemon (npm run sync) stands in for this.
CLERK_WEBHOOK_SECRET=
# Platform super-admin(s): comma-separated Clerk user ids who manage all clinics
# (create clinics, provision receptionists, see cross-clinic usage). Everyone else
# with an active clinic org is a receptionist scoped to that one clinic.
SUPER_ADMIN_USER_IDS=

# --- Supabase (Postgres, RLS scoped per tenant/org) -------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Booking brain (OpenAI) -------------------------------------------------
# The booking agent (WhatsApp + voice + dashboard simulator) runs on OpenAI.
# OPENAI_BOOKING_MODEL defaults to gpt-4.1 if unset.
OPENAI_API_KEY=
OPENAI_BOOKING_MODEL=gpt-4.1

# --- WhatsApp via Meta Cloud API (direct) -----------------------------------
# From Meta App → WhatsApp → API Setup:
#
# WHATSAPP_ACCESS_TOKEN          = access token (temporary 24h in sandbox; create a
#                                  permanent System User token for production)
# WHATSAPP_PHONE_NUMBER_ID       = "Phone Number ID" of the sending number
# WHATSAPP_BUSINESS_ACCOUNT_ID   = "WhatsApp Business Account ID" (WABA id)
# WHATSAPP_GRAPH_VERSION         = Graph API version (e.g. v23.0)
# WHATSAPP_APP_SECRET            = App → Settings → Basic → App Secret
#                                  (verifies webhook signatures; leave blank in dev)
# WHATSAPP_WEBHOOK_VERIFY_TOKEN  = any string you choose; set the SAME value in the
#                                  Meta webhook config "Verify token" field
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_GRAPH_VERSION=v23.0
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=hodoor-webhook-2026
#
# Booking confirmation template (must be APPROVED in WhatsApp Manager). Defaults
# to appointment_confirmation / ar. Body params order: clinic name, service_ar, when.
WHATSAPP_CONFIRM_TEMPLATE=appointment_confirmation
WHATSAPP_TEMPLATE_LANG=ar
#
# Routing fallback for the single sandbox number. Set WHATSAPP_SANDBOX_OWNER_ID to
# your Clerk user ID. Before onboarding a 2nd clinic, ALSO set
# WHATSAPP_SANDBOX_PHONE_NUMBER_ID to the sandbox "Phone Number ID" so the fallback
# fires ONLY for that number and real clinics' unmatched numbers are dropped.
WHATSAPP_SANDBOX_OWNER_ID=
WHATSAPP_SANDBOX_PHONE_NUMBER_ID=
#
# Webhook URL to register in Meta (WhatsApp → Configuration → Callback URL):
#   https://<your-vercel-domain>/api/whatsapp/webhook

# --- Voice (Vapi telephony + Hakim Gulf-Arabic TTS) -------------------------
# Vapi assistant points at:
#   Custom-LLM  → https://<domain>/api/voice/chat/completions   (auth: VAPI_SECRET)
#   Custom-Voice→ https://<domain>/api/voice/tts?key=<VAPI_TTS_SECRET>  (Hakim proxy)
# If a secret is unset the matching route accepts requests unauthenticated — set
# both in production.
VAPI_SECRET=
VAPI_TTS_SECRET=
# Routes voice calls to a single clinic until per-assistant routing exists.
VOICE_SANDBOX_OWNER_ID=
# Hakim TTS (api.tryhakim.ai). Defaults: base https://ksa.api.tryhakim.ai,
# model hakim-fast-v1, voice reem-khaleeji.
HAKIM_API_KEY=
HAKIM_TTS_BASE=https://ksa.api.tryhakim.ai
HAKIM_TTS_MODEL=hakim-fast-v1
HAKIM_TTS_VOICE=reem-khaleeji

# --- Site -------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
