# ----------------------------------------------------------------------------
# VibeQuarter — environment. Copy to .env.local. The site runs WITHOUT these
# (auth + data are mocked) so you can preview immediately; add them to switch on
# real auth, billing, and the database.
# ----------------------------------------------------------------------------

# --- Clerk (auth, organizations / multi-tenancy, billing) -------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# --- Supabase (Postgres, RLS scoped per tenant/org) -------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- AI builder engine (server-only — NOT NEXT_PUBLIC) ----------------------
# The builder chat uses this to generate/edit sites with Claude. The plan's
# model tier (Haiku/Sonnet/Opus) is chosen server-side per user.
ANTHROPIC_API_KEY=

# --- WhatsApp via Meta Cloud API (direct) -----------------------------------
# From Meta App → WhatsApp → API Setup (Step 1. Try it out):
#
# WHATSAPP_ACCESS_TOKEN        = access token (temporary 24h in sandbox; create a
#                                permanent System User token for production)
# WHATSAPP_PHONE_NUMBER_ID     = "Phone Number ID" of the sending number
# WHATSAPP_BUSINESS_ACCOUNT_ID = "WhatsApp Business Account ID" (WABA id)
# WHATSAPP_GRAPH_VERSION       = Graph API version (e.g. v23.0)
# WHATSAPP_APP_SECRET          = App → Settings → Basic → App Secret
#                                (verifies webhook signatures; leave blank in dev)
# WHATSAPP_WEBHOOK_VERIFY_TOKEN = any string you choose; set the SAME value in the
#                                Meta webhook config "Verify token" field
# WHATSAPP_SANDBOX_OWNER_ID    = your Clerk user ID — routes the single sandbox number
#                                to your clinic when it isn't matched in the DB
#
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_GRAPH_VERSION=v23.0
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=hodoor-webhook-2026
WHATSAPP_SANDBOX_OWNER_ID=

# Webhook URL to register in Meta (WhatsApp → Configuration → Callback URL):
#   https://<your-vercel-domain>/api/whatsapp/webhook

# --- Site -------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
